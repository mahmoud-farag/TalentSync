{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:development": "cross-env NODE_ENV=development nest build",
    "build:production": "cross-env NODE_ENV=production nest build",
    "build:test": "cross-env NODE_ENV=test nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "start:development": "cross-env NODE_ENV=development nest start --watch",
    "start:dev": "pnpm start:development",
    "start:test": "cross-env NODE_ENV=test nest start",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:production": "cross-env NODE_ENV=production node dist/main",
    "start:prod": "pnpm start:production",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./test/jest-e2e.json",
    "prisma:generate:development": "pnpm prisma:generate:platform:development && pnpm prisma:generate:workspace:development",
    "prisma:generate:production": "pnpm prisma:generate:platform:production && pnpm prisma:generate:workspace:production",
    "prisma:generate:test": "pnpm prisma:generate:platform:test && pnpm prisma:generate:workspace:test",
    "prisma:generate:platform:development": "pnpm exec dotenv -e .env.development -- prisma generate --config ./prisma/platform/prisma.config.ts",
    "prisma:generate:platform:production": "pnpm exec dotenv -e .env.production -- prisma generate --config ./prisma/platform/prisma.config.ts",
    "prisma:generate:platform:test": "pnpm exec dotenv -e .env.test -- prisma generate --config ./prisma/platform/prisma.config.ts",
    "prisma:generate:workspace:development": "pnpm exec dotenv -e .env.development -- prisma generate --config ./prisma/workspace/prisma.config.ts",
    "prisma:generate:workspace:production": "pnpm exec dotenv -e .env.production -- prisma generate --config ./prisma/workspace/prisma.config.ts",
    "prisma:generate:workspace:test": "pnpm exec dotenv -e .env.test -- prisma generate --config ./prisma/workspace/prisma.config.ts",
    "prisma:migrate:platform:development": "pnpm exec dotenv -e .env.development -- prisma migrate dev --config ./prisma/platform/prisma.config.ts",
    "prisma:migrate:platform:production": "pnpm exec dotenv -e .env.production -- prisma migrate deploy --config ./prisma/platform/prisma.config.ts",
    "prisma:migrate:platform:test": "pnpm exec dotenv -e .env.test -- prisma migrate deploy --config ./prisma/platform/prisma.config.ts",
    "prisma:sync:workspace:development": "pnpm exec dotenv -e .env.development -- prisma db push --config ./prisma/workspace/prisma.config.ts",
    "prisma:sync:workspace:production": "pnpm exec dotenv -e .env.production -- prisma db push --config ./prisma/workspace/prisma.config.ts",
    "prisma:sync:workspace:test": "pnpm exec dotenv -e .env.test -- prisma db push --config ./prisma/workspace/prisma.config.ts",
    "tenant:schema:push": "node ./scripts/push-workspace-schema.local.cjs",
    "tenant:schema:push:all": "node ./scripts/push-workspace-schema.local.cjs --all",
    "prisma:migrate:workspace:development": "pnpm run prisma:sync:workspace:development",
    "prisma:migrate:workspace:production": "pnpm run prisma:sync:workspace:production",
    "prisma:migrate:workspace:test": "pnpm run prisma:sync:workspace:test"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "graphql": "^16.13.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
