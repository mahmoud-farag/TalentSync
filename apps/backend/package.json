{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:development": "cross-env NODE_ENV=development nest build",
    "build:production": "cross-env NODE_ENV=production nest build",
    "build:test": "cross-env NODE_ENV=test nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "cross-env NODE_ENV=development nest start --watch",
    "start:development": "cross-env NODE_ENV=development nest start --watch",
    "start:dev": "pnpm start:development",
    "start:test": "cross-env NODE_ENV=test nest start",
    "start:debug": "cross-env NODE_ENV=development nest start --debug --watch",
    "start:production": "cross-env NODE_ENV=production node dist/main",
    "start:prod": "pnpm start:production",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./test/jest-e2e.json",
    "prisma:generate:development": "cross-env NODE_ENV=development DOTENV_CONFIG_PATH=.env.development prisma generate",
    "prisma:generate:production": "cross-env NODE_ENV=production DOTENV_CONFIG_PATH=.env.production prisma generate",
    "prisma:generate:test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test prisma generate",
    "prisma:migrate:development": "cross-env NODE_ENV=development DOTENV_CONFIG_PATH=.env.development prisma migrate dev",
    "prisma:migrate:production": "cross-env NODE_ENV=production DOTENV_CONFIG_PATH=.env.production prisma migrate deploy",
    "prisma:migrate:test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test prisma migrate deploy"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^7.6.0",
    "graphql": "^16.13.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "cross-env": "^10.1.0",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
