/// Normalized skill dictionary for this company workspace.
model Skill {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(100)
  slug            String           @unique @db.VarChar(120)
  category        String?          @db.VarChar(100)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  candidateSkills CandidateSkill[]
  jobSkills       JobSkill[]

  @@map("skills")
}

/// Candidate-to-skill join with proficiency metadata.
model CandidateSkill {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @map("candidate_profile_id") @db.Uuid
  skillId            String           @map("skill_id") @db.Uuid
  proficiency        Int?
  yearsExperience    Decimal?         @map("years_experience") @db.Decimal(4, 1)
  source             String?          @db.VarChar(50)
  confidence         Decimal?         @db.Decimal(4, 3)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  skill              Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, skillId])
  @@map("candidate_skills")
}

// ---------------------------------------------------------------
// CVs & JOB SEARCH
// ---------------------------------------------------------------

/// CV/resume upload metadata.
model Cv {
  id                 String           @id @default(uuid()) @db.Uuid
  candidateProfileId String           @map("candidate_profile_id") @db.Uuid
  fileName           String           @map("file_name")
  filePath           String           @map("file_path")
  fileSize           Int              @map("file_size")
  fileType           String           @map("file_type")
  status             CvStatus         @default(PENDING)
  parsedData         Json?            @map("parsed_data")
  isPrimary          Boolean          @default(false) @map("is_primary")
  lastUsedAt         DateTime?        @map("last_used_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  applications       Application[]

  @@index([candidateProfileId, isPrimary])
  @@map("cvs")
}

/// Persisted job search filter definitions for job alerts and quick reuse.
model SavedSearch {
  id                 String                @id @default(uuid()) @db.Uuid
  candidateProfileId String                @map("candidate_profile_id") @db.Uuid
  name               String                @db.VarChar(100)
  filters            Json
  frequency          SearchAlertFrequency?
  lastNotifiedAt     DateTime?             @map("last_notified_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  candidateProfile   CandidateProfile      @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}
