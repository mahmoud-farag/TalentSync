/// Control-plane record for each company/workspace.
/// The only purpose of this table is company routing and provisioning.
/// All application data (users, jobs, etc.) lives in the dedicated company database.
model Company {
  /// Primary identifier for the company.
  id           String        @id @default(uuid()) @db.Uuid
  /// Human-readable company name.
  name         String        @db.VarChar(100)
  /// URL-safe unique identifier used for hostname matching (e.g. "localhost1").
  slug         String        @unique @db.VarChar(120)
  /// Full connection URL to the company's dedicated database.
  databaseUrl  String        @map("database_url")
  /// Lifecycle state of the company.
  status       CompanyStatus @default(ACTIVE)
  /// S3 bucket name provisioned for this company's file storage.
  s3BucketName String?       @map("s3_bucket_name") @db.VarChar(200)
  /// S3 bucket region or path prefix for this company.
  s3BucketKey  String?       @map("s3_bucket_key") @db.VarChar(200)
  /// Flexible provisioning metadata (e.g. region, plan tier, feature flags).
  metadata     Json?
  /// Row creation timestamp.
  createdAt    DateTime      @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("companies")
}
