generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CANDIDATE
  RECRUITER
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  ADMIN
  RECRUITER
  VIEWER
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  EXECUTIVE
}

enum RemoteType {
  ONSITE
  HYBRID
  REMOTE
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
  ANONYMOUS
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum CvStatus {
  PENDING
  PARSING
  PARSED
  FAILED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  ARCHIVED
}

enum QuestionType {
  TEXT
  TEXTAREA
  SINGLE_SELECT
  MULTI_SELECT
  BOOLEAN
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

enum ApplicationSource {
  DIRECT
  RECOMMENDATION
  ALERT
}

enum MatchTrigger {
  CV_UPLOAD
  PROFILE_UPDATE
  JOB_POSTED
  JOB_UPDATED
  MANUAL_REFRESH
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum BillingInterval {
  MONTHLY
  YEARLY
  CUSTOM
}

enum QuotaFeature {
  ACTIVE_JOBS
  TEAM_MEMBERS
  CANDIDATE_UNLOCKS
  CV_PARSING
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_STATUS_CHANGED
  JOB_MATCH
  JOB_ALERT
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  TEAM_INVITATION
  MESSAGE_RECEIVED
}

enum NotificationChannel {
  EMAIL
  IN_APP
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum SearchAlertFrequency {
  DAILY
  WEEKLY
}

/// Global account record for every human actor in the platform.
/// This table answers: who can log in, what kind of account they are,
/// and what the current security/authentication state is.
model User {
  /// Primary identifier used by all related tables.
  id                     String                   @id @default(uuid()) @db.Uuid
  /// Unique login and communication address across the whole platform.
  email                  String                   @unique @db.VarChar(320)
  /// Stored password hash; nullable to support future OAuth-only users.
  passwordHash           String?                  @map("password_hash")
  /// Distinguishes candidate accounts from recruiter accounts.
  accountType            AccountType              @map("account_type")
  /// Lifecycle state controlling whether login and platform access are allowed.
  status                 UserStatus               @default(PENDING_VERIFICATION)
  /// Fast flag used by auth flows after verification token redemption.
  emailVerified          Boolean                  @default(false) @map("email_verified")
  /// Counter for brute-force protection and temporary account lockout.
  failedLoginAttempts    Int                      @default(0) @map("failed_login_attempts")
  /// Useful for dashboards, auditing, and anomaly detection.
  lastLoginAt            DateTime?                @map("last_login_at")
  /// Timestamp until which login should be blocked after repeated failures.
  lockedUntil            DateTime?                @map("locked_until")
  /// Soft-delete marker to retain historical references without hard deletion.
  deletedAt              DateTime?                @map("deleted_at")
  /// Creation timestamp for audit trails and ordering.
  createdAt              DateTime                 @default(now()) @map("created_at")
  /// Auto-managed update timestamp for change tracking.
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  /// One-to-one general profile information.
  profile                UserProfile?
  /// Optional candidate-specific extension.
  candidateProfile       CandidateProfile?
  /// Company memberships for recruiter-side access.
  memberships            TenantMembership[]
  /// Invitations this user has sent to future team members.
  invitationsSent        Invitation[]             @relation("InvitationsSent")
  /// Membership rows created through this inviter.
  membershipsInvited     TenantMembership[]       @relation("MembershipInvitedBy")
  /// Jobs this user created as a recruiter.
  createdJobs            Job[]                    @relation("JobsCreatedBy")
  /// Email verification token history.
  verificationTokens     VerificationToken[]
  /// Password reset token history.
  passwordResetTokens    PasswordResetToken[]
  /// Active and historical refresh-token based sessions.
  sessions               Session[]
  /// Linked OAuth identities for future social sign-in.
  oauthAccounts          OAuthAccount[]
  /// Notifications addressed to this user.
  notifications          Notification[]
  /// User-level delivery and channel preferences.
  notificationPreference NotificationPreference?
  /// Candidate contact unlock actions performed by this user.
  contactUnlocks         ContactUnlock[]
  /// Internal notes this user authored on applications.
  applicationNotes       ApplicationNote[]
  /// Application status events performed by this user.
  applicationEvents      ApplicationStatusEvent[]

  @@map("users")
}

/// Shared person-facing profile data kept separate from authentication fields.
/// This avoids mixing security concerns with editable personal information.
model UserProfile {
  /// Primary key for the profile row.
  id                String            @id @default(uuid()) @db.Uuid
  /// Owning account; one profile per user.
  userId            String            @unique @map("user_id") @db.Uuid
  /// Human-readable given name for display and emails.
  firstName         String            @map("first_name") @db.VarChar(50)
  /// Human-readable family name for display and emails.
  lastName          String            @map("last_name") @db.VarChar(50)
  /// Optional phone number used for contact and future verification.
  phone             String?           @db.VarChar(32)
  /// Optional city for profile display and matching context.
  city              String?           @db.VarChar(100)
  /// Optional country for location filters and relocation logic.
  country           String?           @db.VarChar(100)
  /// IANA timezone or equivalent for notifications and scheduling.
  timezone          String?           @db.VarChar(100)
  /// Avatar/image location, typically on object storage.
  profilePhotoUrl   String?           @map("profile_photo_url")
  /// Cached completion percentage for onboarding and nudges.
  profileCompletion Int               @default(0) @map("profile_completion")
  /// High-level visibility mode for privacy controls.
  visibility        ProfileVisibility @default(PRIVATE)
  /// Search inclusion toggle for candidate discovery.
  appearsInSearch   Boolean           @default(true) @map("appears_in_search")
  /// Per-field visibility overrides when product needs granular privacy.
  fieldVisibility   Json?             @map("field_visibility")
  /// Flexible settings bucket for UI/account preferences not yet normalized.
  settings          Json?
  /// Row creation timestamp.
  createdAt         DateTime          @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt         DateTime          @updatedAt @map("updated_at")
  /// Inverse relation back to the owning user.
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// Candidate-specific extension of a user account.
/// This is the core profile used by search, matching, recommendations, and applications.
model CandidateProfile {
  /// Primary key for candidate profile data.
  id                        String              @id @default(uuid()) @db.Uuid
  /// One candidate profile per user account.
  userId                    String              @unique @map("user_id") @db.Uuid
  /// Short professional headline for cards and search results.
  headline                  String?             @db.VarChar(100)
  /// Free-text professional summary entered or enriched by parsing.
  summary                   String?
  /// Normalized seniority signal used in search and matching.
  experienceLevel           ExperienceLevel?    @map("experience_level")
  /// Remote/hybrid/on-site preferences used in job fit calculations.
  workPreferences           RemoteType[]        @default([]) @map("work_preferences")
  /// Countries the candidate prefers for work opportunities.
  preferredCountries        String[]            @default([]) @map("preferred_countries")
  /// Structured visa requirements or work authorization details.
  visaStatuses              Json?               @map("visa_statuses")
  /// Whether the candidate is open to relocation offers.
  relocation                Boolean             @default(false)
  /// Lower bound of desired compensation.
  salaryExpectationMin      Int?                @map("salary_expectation_min")
  /// Upper bound of desired compensation.
  salaryExpectationMax      Int?                @map("salary_expectation_max")
  /// Currency for salary expectation comparison.
  salaryExpectationCurrency String?             @map("salary_expectation_currency") @db.VarChar(3)
  /// Optional machine-generated summary from CV parsing/enrichment.
  parsedSummary             Json?               @map("parsed_summary")
  /// Row creation timestamp.
  createdAt                 DateTime            @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt                 DateTime            @updatedAt @map("updated_at")
  /// Link to the owning account.
  user                      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Normalized skills with proficiency metadata.
  skills                    CandidateSkill[]
  /// Candidate CV/resume uploads.
  cvs                       Cv[]
  /// Applications submitted by this candidate.
  applications              Application[]
  /// Recruiter-facing job-to-candidate matches.
  matches                   JobCandidateMatch[]
  /// Saved searches and alert definitions.
  savedSearches             SavedSearch[]
  /// Candidate-facing recommended jobs.
  recommendations           JobRecommendation[]
  /// Recruiter contact unlock records targeting this candidate.
  contactUnlocks            ContactUnlock[]

  @@map("candidate_profiles")
}

/// Company/workspace record representing a recruiting organization.
/// Tenant-scoped data such as jobs, quotas, and billing attach here.
model Tenant {
  /// Primary identifier for the company/workspace.
  id             String             @id @default(uuid()) @db.Uuid
  /// Public company name.
  name           String             @db.VarChar(100)
  /// URL-safe unique identifier for subpaths and lookup.
  slug           String             @unique @db.VarChar(120)
  /// Current lifecycle state of the tenant.
  status         TenantStatus       @default(ACTIVE)
  /// Control-plane pointer for future per-tenant database routing.
  databaseUrl    String?            @map("database_url")
  /// Branding asset used across recruiter experiences.
  logoUrl        String?            @map("logo_url")
  /// Flexible branding settings such as colors and theme tokens.
  branding       Json?
  /// Flexible tenant settings and feature toggles.
  settings       Json?
  /// Row creation timestamp.
  createdAt      DateTime           @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt      DateTime           @updatedAt @map("updated_at")
  /// Members belonging to this tenant.
  memberships    TenantMembership[]
  /// Outstanding and historical invitations for this tenant.
  invitations    Invitation[]
  /// Jobs posted under this tenant/company.
  jobs           Job[]
  /// Current billing subscription for this tenant.
  subscription   Subscription?
  /// Quota counters for plan enforcement.
  quotaUsage     QuotaUsage[]
  /// Candidate contact unlocks performed by this tenant.
  contactUnlocks ContactUnlock[]
  /// External webhook events associated with this tenant.
  webhookEvents  WebhookEvent[]

  @@map("tenants")
}

/// Join table between a global user account and a tenant.
/// This is where tenant-specific role and membership state live.
model TenantMembership {
  /// Primary key for the membership row.
  id               String            @id @default(uuid()) @db.Uuid
  /// The person who belongs to the tenant.
  userId           String            @map("user_id") @db.Uuid
  /// The tenant/company they belong to.
  tenantId         String            @map("tenant_id") @db.Uuid
  /// Role controlling recruiter/admin/owner permissions.
  role             TenantRole
  /// Optional inviter who created the membership path.
  invitedById      String?           @map("invited_by_id") @db.Uuid
  /// When the user actually joined/accepted.
  joinedAt         DateTime?         @map("joined_at")
  /// Row creation timestamp.
  createdAt        DateTime          @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt        DateTime          @updatedAt @map("updated_at")
  /// Owning user relation.
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Owning tenant relation.
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Optional relation back to the inviter.
  invitedBy        User?             @relation("MembershipInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  /// Recruiter-specific professional metadata in this tenant context.
  recruiterProfile RecruiterProfile?

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_memberships")
}

/// Recruiter-specific metadata attached to a tenant membership.
/// This is tenant-contextual because role/title may vary between companies.
model RecruiterProfile {
  /// Primary key for recruiter profile data.
  id           String           @id @default(uuid()) @db.Uuid
  /// One recruiter profile per membership.
  membershipId String           @unique @map("membership_id") @db.Uuid
  /// Recruiter's title inside the company.
  jobTitle     String?          @map("job_title") @db.VarChar(100)
  /// Department/team for filtering and organization.
  department   String?          @db.VarChar(100)
  /// Optional public professional profile link.
  linkedinUrl  String?          @map("linkedin_url")
  /// Row creation timestamp.
  createdAt    DateTime         @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt    DateTime         @updatedAt @map("updated_at")
  /// Membership that this recruiter metadata extends.
  membership   TenantMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@map("recruiter_profiles")
}

/// Invitation sent to an email address before a membership exists.
/// Supports team growth and role-based onboarding.
model Invitation {
  /// Primary key for invitation tracking.
  id          String           @id @default(uuid()) @db.Uuid
  /// Target email address of the invitee.
  email       String           @db.VarChar(320)
  /// Tenant the invite grants access to.
  tenantId    String           @map("tenant_id") @db.Uuid
  /// Role the invitee should receive on acceptance.
  role        TenantRole
  /// User who sent the invitation.
  invitedById String           @map("invited_by_id") @db.Uuid
  /// Unique acceptance token sent by email.
  token       String           @unique @db.Uuid
  /// Current invitation state.
  status      InvitationStatus @default(PENDING)
  /// Expiration time for security and quota control.
  expiresAt   DateTime         @map("expires_at")
  /// When the invitation was accepted, if ever.
  acceptedAt  DateTime?        @map("accepted_at")
  /// Row creation timestamp.
  createdAt   DateTime         @default(now()) @map("created_at")
  /// Owning tenant relation.
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Inviter relation.
  invitedBy   User             @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([tenantId, email, status])
  @@map("invitations")
}

/// Email verification tokens for account activation.
/// Kept in a dedicated table so they can expire and be audited independently.
model VerificationToken {
  /// Primary key for token row.
  id        String    @id @default(uuid()) @db.Uuid
  /// User whose email is being verified.
  userId    String    @map("user_id") @db.Uuid
  /// Unique token included in verification links.
  token     String    @unique @db.Uuid
  /// Expiration time to limit token reuse.
  expiresAt DateTime  @map("expires_at")
  /// One-time-use marker after successful verification.
  usedAt    DateTime? @map("used_at")
  /// Row creation timestamp.
  createdAt DateTime  @default(now()) @map("created_at")
  /// Owning user relation.
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_tokens")
}

/// Password reset tokens for secure recovery flows.
/// Separate from sessions because they are short-lived, one-time credentials.
model PasswordResetToken {
  /// Primary key for token row.
  id        String    @id @default(uuid()) @db.Uuid
  /// User requesting password recovery.
  userId    String    @map("user_id") @db.Uuid
  /// Unique token included in reset links.
  token     String    @unique @db.Uuid
  /// Expiration time to reduce attack window.
  expiresAt DateTime  @map("expires_at")
  /// One-time-use marker once password has been reset.
  usedAt    DateTime? @map("used_at")
  /// Row creation timestamp.
  createdAt DateTime  @default(now()) @map("created_at")
  /// Owning user relation.
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

/// Refresh-token backed authenticated session.
/// Needed for logout, rotation, concurrent session limits, and device tracking.
model Session {
  /// Primary key for a logical session/device login.
  id               String    @id @default(uuid()) @db.Uuid
  /// User who owns the session.
  userId           String    @map("user_id") @db.Uuid
  /// Hashed refresh token so plaintext tokens are never stored.
  refreshTokenHash String    @map("refresh_token_hash")
  /// Token family identifier used for rotation and reuse detection.
  familyId         String    @map("family_id") @db.Uuid
  /// Flexible device fingerprint payload.
  deviceInfo       Json?     @map("device_info")
  /// Captured user agent for device display and anomaly detection.
  userAgent        String?   @map("user_agent")
  /// Hashed IP rather than raw IP for privacy-aware tracking.
  ipHash           String?   @map("ip_hash")
  /// Session expiration time.
  expiresAt        DateTime  @map("expires_at")
  /// When the session was revoked/logged out.
  revokedAt        DateTime? @map("revoked_at")
  /// Last refresh/use timestamp.
  lastUsedAt       DateTime? @map("last_used_at")
  /// Row creation timestamp.
  createdAt        DateTime  @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt        DateTime  @updatedAt @map("updated_at")
  /// Owning user relation.
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("sessions")
}

/// Linked social identity for future OAuth-based authentication.
model OAuthAccount {
  /// Primary key for the linked provider record.
  id             String   @id @default(uuid()) @db.Uuid
  /// Local user account linked to the provider.
  userId         String   @map("user_id") @db.Uuid
  /// Provider name such as linkedin or google.
  provider       String   @db.VarChar(50)
  /// Provider-side immutable user identifier.
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  /// Row creation timestamp.
  createdAt      DateTime @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt      DateTime @updatedAt @map("updated_at")
  /// Owning user relation.
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

/// Normalized skill dictionary shared by candidates and jobs.
/// Prevents duplicate free-text skill strings from fragmenting search/matching.
model Skill {
  /// Primary key for the skill entry.
  id              String           @id @default(uuid()) @db.Uuid
  /// Canonical display name.
  name            String           @unique @db.VarChar(100)
  /// URL-safe / machine-safe normalized version.
  slug            String           @unique @db.VarChar(120)
  /// Optional grouping such as frontend, backend, cloud.
  category        String?          @db.VarChar(100)
  /// Row creation timestamp.
  createdAt       DateTime         @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt       DateTime         @updatedAt @map("updated_at")
  /// Candidate-side many-to-many relation payloads.
  candidateSkills CandidateSkill[]
  /// Job-side many-to-many relation payloads.
  jobSkills       JobSkill[]

  @@map("skills")
}

/// Candidate-to-skill join with scoring metadata.
/// Stores not just the existence of a skill, but how strong/confident it is.
model CandidateSkill {
  /// Primary key for the join row.
  id                 String           @id @default(uuid()) @db.Uuid
  /// Candidate profile that owns this skill claim.
  candidateProfileId String           @map("candidate_profile_id") @db.Uuid
  /// Skill being claimed.
  skillId            String           @map("skill_id") @db.Uuid
  /// Optional normalized proficiency level.
  proficiency        Int?
  /// Optional years of experience for ranking and fit.
  yearsExperience    Decimal?         @map("years_experience") @db.Decimal(4, 1)
  /// Origin of this skill, e.g. manual, parsed, inferred.
  source             String?          @db.VarChar(50)
  /// Confidence score from parsing/AI enrichment pipelines.
  confidence         Decimal?         @db.Decimal(4, 3)
  /// Row creation timestamp.
  createdAt          DateTime         @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt          DateTime         @updatedAt @map("updated_at")
  /// Candidate relation.
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  /// Skill relation.
  skill              Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, skillId])
  @@map("candidate_skills")
}

/// CV/resume upload metadata.
/// This stores file bookkeeping and parsing status, not just the raw file itself.
model Cv {
  /// Primary key for the uploaded CV.
  id                 String           @id @default(uuid()) @db.Uuid
  /// Candidate who owns this CV.
  candidateProfileId String           @map("candidate_profile_id") @db.Uuid
  /// Original filename shown in UI.
  fileName           String           @map("file_name")
  /// Object-storage key/path used to retrieve the file.
  filePath           String           @map("file_path")
  /// File size for validation and display.
  fileSize           Int              @map("file_size")
  /// MIME type for validation and parsing logic selection.
  fileType           String           @map("file_type")
  /// Current upload/parsing lifecycle state.
  status             CvStatus         @default(PENDING)
  /// Structured extraction payload produced by parsing workers.
  parsedData         Json?            @map("parsed_data")
  /// Whether this is the default CV used in applications.
  isPrimary          Boolean          @default(false) @map("is_primary")
  /// Last time this CV was used to apply.
  lastUsedAt         DateTime?        @map("last_used_at")
  /// Row creation timestamp.
  createdAt          DateTime         @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt          DateTime         @updatedAt @map("updated_at")
  /// Candidate relation.
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  /// Applications submitted using this CV.
  applications       Application[]

  @@index([candidateProfileId, isPrimary])
  @@map("cvs")
}

/// Persisted job search filter definitions for job alerts and quick reuse.
model SavedSearch {
  /// Primary key for the saved search.
  id                 String                @id @default(uuid()) @db.Uuid
  /// Candidate who saved the search.
  candidateProfileId String                @map("candidate_profile_id") @db.Uuid
  /// Human-readable name for the saved search.
  name               String                @db.VarChar(100)
  /// Serialized search filter payload.
  filters            Json
  /// How often alerts should be generated for this search.
  frequency          SearchAlertFrequency?
  /// Last time an alert was sent for this search.
  lastNotifiedAt     DateTime?             @map("last_notified_at")
  /// Row creation timestamp.
  createdAt          DateTime              @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt          DateTime              @updatedAt @map("updated_at")
  /// Owning candidate relation.
  candidateProfile   CandidateProfile      @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@map("saved_searches")
}

/// Core recruiter-side job posting entity.
/// This is the central object searched by candidates and managed by recruiters.
model Job {
  /// Primary key for the job posting.
  id               String              @id @default(uuid()) @db.Uuid
  /// Tenant/company that owns the job.
  tenantId         String              @map("tenant_id") @db.Uuid
  /// User who created the posting.
  createdById      String              @map("created_by_id") @db.Uuid
  /// Public job title.
  title            String              @db.VarChar(100)
  /// URL-safe unique identifier for public job pages.
  slug             String              @unique @db.VarChar(140)
  /// Full rich-text job description.
  description      String
  /// Detailed qualification requirements.
  requirements     String
  /// City used for search filtering and display.
  city             String?             @db.VarChar(100)
  /// Country used for search filtering and compliance context.
  country          String?             @db.VarChar(100)
  /// Remote/on-site/hybrid mode.
  remoteType       RemoteType?         @map("remote_type")
  /// Flexible location payload for future coordinates/radius support.
  locationMeta     Json?               @map("location_meta")
  /// Employment type.
  jobType          JobType             @map("job_type")
  /// Desired seniority.
  experienceLevel  ExperienceLevel     @map("experience_level")
  /// Salary lower bound.
  salaryMin        Int?                @map("salary_min")
  /// Salary upper bound.
  salaryMax        Int?                @map("salary_max")
  /// Salary currency code.
  salaryCurrency   String?             @map("salary_currency") @db.VarChar(3)
  /// Whether salary is publicly visible.
  salaryIsPublic   Boolean             @default(false) @map("salary_is_public")
  /// Benefits list shown to candidates.
  benefits         String[]            @default([])
  /// Whether company offers visa sponsorship for this role.
  visaSponsorship  Boolean             @default(false) @map("visa_sponsorship")
  /// Whether company supports relocation for this role.
  relocation       Boolean             @default(false)
  /// Job lifecycle state controlling visibility and apply behavior.
  status           JobStatus           @default(DRAFT)
  /// Cached counter used for dashboards and quota views.
  applicationCount Int                 @default(0) @map("application_count")
  /// First publication time.
  publishedAt      DateTime?           @map("published_at")
  /// Optional automatic close time.
  expiresAt        DateTime?           @map("expires_at")
  /// Row creation timestamp.
  createdAt        DateTime            @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt        DateTime            @updatedAt @map("updated_at")
  /// Owning tenant relation.
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Creator relation.
  createdBy        User                @relation("JobsCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  /// Required/preferred job skills.
  skills           JobSkill[]
  /// Screening questions shown during application.
  questions        JobQuestion[]
  /// Applications submitted to this job.
  applications     Application[]
  /// Precomputed recruiter-side candidate matches.
  matches          JobCandidateMatch[]
  /// Candidate-facing recommendation records for this job.
  recommendations  JobRecommendation[]

  @@index([tenantId, status])
  @@index([status, publishedAt])
  @@index([country, city])
  @@map("jobs")
}

/// Job-to-skill join row.
/// Lets the platform mark a skill as attached to a job and whether it is required.
model JobSkill {
  /// Primary key for the join row.
  id         String   @id @default(uuid()) @db.Uuid
  /// Job requiring or preferring the skill.
  jobId      String   @map("job_id") @db.Uuid
  /// Referenced normalized skill.
  skillId    String   @map("skill_id") @db.Uuid
  /// Distinguishes mandatory from nice-to-have requirements.
  isRequired Boolean  @default(true) @map("is_required")
  /// Row creation timestamp.
  createdAt  DateTime @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt  DateTime @updatedAt @map("updated_at")
  /// Job relation.
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /// Skill relation.
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@map("job_skills")
}

/// Structured application questions attached to a job posting.
/// Separating them into rows keeps questions queryable and reusable in UI ordering.
model JobQuestion {
  /// Primary key for the question.
  id         String       @id @default(uuid()) @db.Uuid
  /// Job that owns this question.
  jobId      String       @map("job_id") @db.Uuid
  /// Prompt shown to the candidate.
  question   String
  /// Input type used to render and validate answers.
  type       QuestionType
  /// Whether an answer is mandatory during apply flow.
  isRequired Boolean      @default(false) @map("is_required")
  /// Options payload for select-based questions.
  options    Json?
  /// Stable UI ordering within the job application form.
  sortOrder  Int          @default(0) @map("sort_order")
  /// Row creation timestamp.
  createdAt  DateTime     @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt  DateTime     @updatedAt @map("updated_at")
  /// Job relation.
  job        Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, sortOrder])
  @@map("job_questions")
}

/// Candidate application to a specific job using a specific CV.
/// This is the main business event connecting candidate intent to recruiter workflow.
model Application {
  /// Primary key for the application.
  id                 String                   @id @default(uuid()) @db.Uuid
  /// Candidate submitting the application.
  candidateProfileId String                   @map("candidate_profile_id") @db.Uuid
  /// Job being applied to.
  jobId              String                   @map("job_id") @db.Uuid
  /// CV chosen for this application.
  cvId               String                   @map("cv_id") @db.Uuid
  /// Optional free-text cover letter.
  coverLetter        String?                  @map("cover_letter")
  /// Serialized answers to job-specific custom questions.
  customAnswers      Json?                    @map("custom_answers")
  /// Current stage in the application funnel.
  status             ApplicationStatus        @default(SUBMITTED)
  /// Snapshot of match score at time of application.
  matchScore         Decimal?                 @map("match_score") @db.Decimal(5, 2)
  /// Acquisition source for analytics and attribution.
  source             ApplicationSource        @default(DIRECT)
  /// Soft archive timestamp for historical retention.
  archivedAt         DateTime?                @map("archived_at")
  /// Candidate withdrawal timestamp.
  withdrawnAt        DateTime?                @map("withdrawn_at")
  /// Row creation timestamp.
  createdAt          DateTime                 @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  /// Candidate relation.
  candidateProfile   CandidateProfile         @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  /// Job relation.
  job                Job                      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /// CV relation.
  cv                 Cv                       @relation(fields: [cvId], references: [id], onDelete: Restrict)
  /// Historical state transitions for timeline views and auditability.
  statusHistory      ApplicationStatusEvent[]
  /// Internal recruiter notes attached to the application.
  notes              ApplicationNote[]

  @@unique([candidateProfileId, jobId])
  @@index([jobId, status])
  @@index([candidateProfileId, status])
  @@map("applications")
}

/// Historical record of application stage transitions.
/// Keeps the current status on Application lean while preserving a full timeline.
model ApplicationStatusEvent {
  /// Primary key for the status event.
  id            String             @id @default(uuid()) @db.Uuid
  /// Application whose stage changed.
  applicationId String             @map("application_id") @db.Uuid
  /// Previous stage; null for the initial event.
  fromStatus    ApplicationStatus? @map("from_status")
  /// New stage after the transition.
  toStatus      ApplicationStatus  @map("to_status")
  /// User who performed the transition, when known.
  changedById   String?            @map("changed_by_id") @db.Uuid
  /// Optional human explanation for the transition.
  note          String?
  /// Extra structured metadata such as rejection reason or interview details.
  metadata      Json?
  /// Event creation timestamp.
  createdAt     DateTime           @default(now()) @map("created_at")
  /// Application relation.
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  /// User relation for the actor who changed status.
  changedBy     User?              @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([applicationId, createdAt])
  @@map("application_status_events")
}

/// Internal recruiter note attached to an application.
/// Useful for collaboration without altering the application's formal status.
model ApplicationNote {
  /// Primary key for the note.
  id            String      @id @default(uuid()) @db.Uuid
  /// Application this note belongs to.
  applicationId String      @map("application_id") @db.Uuid
  /// User who wrote the note.
  authorId      String      @map("author_id") @db.Uuid
  /// Note content.
  body          String
  /// Whether note should remain internal-only.
  isInternal    Boolean     @default(true) @map("is_internal")
  /// Row creation timestamp.
  createdAt     DateTime    @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt     DateTime    @updatedAt @map("updated_at")
  /// Application relation.
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  /// Author relation.
  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@map("application_notes")
}

/// Precomputed recruiter-facing job-to-candidate match result.
/// Storing scores avoids recalculating expensive matching logic on every request.
model JobCandidateMatch {
  /// Primary key for the match row.
  id                 String           @id @default(uuid()) @db.Uuid
  /// Job being matched.
  jobId              String           @map("job_id") @db.Uuid
  /// Candidate being matched.
  candidateProfileId String           @map("candidate_profile_id") @db.Uuid
  /// Overall weighted match score.
  score              Decimal          @db.Decimal(5, 2)
  /// Skills component of the match.
  skillsScore        Decimal?         @map("skills_score") @db.Decimal(5, 2)
  /// Experience component of the match.
  experienceScore    Decimal?         @map("experience_score") @db.Decimal(5, 2)
  /// Location component of the match.
  locationScore      Decimal?         @map("location_score") @db.Decimal(5, 2)
  /// Preference compatibility component.
  preferenceScore    Decimal?         @map("preference_score") @db.Decimal(5, 2)
  /// Freshness/activity component.
  recencyScore       Decimal?         @map("recency_score") @db.Decimal(5, 2)
  /// Human-readable or machine-readable explanation payload.
  explanation        Json?
  /// Trigger that caused this match to be calculated.
  trigger            MatchTrigger?
  /// Row creation timestamp.
  createdAt          DateTime         @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt          DateTime         @updatedAt @map("updated_at")
  /// Job relation.
  job                Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  /// Candidate relation.
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateProfileId])
  @@index([candidateProfileId, score])
  @@map("job_candidate_matches")
}

/// Candidate-facing recommendation row.
/// Separate from recruiter match inventory because recommendations have their own UX lifecycle.
model JobRecommendation {
  /// Primary key for recommendation row.
  id                 String           @id @default(uuid()) @db.Uuid
  /// Candidate receiving the recommendation.
  candidateProfileId String           @map("candidate_profile_id") @db.Uuid
  /// Recommended job.
  jobId              String           @map("job_id") @db.Uuid
  /// Recommendation score.
  score              Decimal          @db.Decimal(5, 2)
  /// Explanation payload shown in UI or debugging.
  explanation        Json?
  /// When the candidate dismissed the recommendation.
  dismissedAt        DateTime?        @map("dismissed_at")
  /// Row creation timestamp.
  createdAt          DateTime         @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt          DateTime         @updatedAt @map("updated_at")
  /// Candidate relation.
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  /// Job relation.
  job                Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([candidateProfileId, jobId])
  @@index([candidateProfileId, score])
  @@map("job_recommendations")
}

/// Catalog of available subscription plans.
/// This defines product limits and pricing independently from who is subscribed.
model SubscriptionPlan {
  /// Primary key for the plan.
  id                   String          @id @default(uuid()) @db.Uuid
  /// Human-readable plan name such as Free or Pro.
  name                 String          @unique @db.VarChar(50)
  /// Stable machine identifier for code and integrations.
  code                 String          @unique @db.VarChar(50)
  /// Optional descriptive copy for billing UI.
  description          String?
  /// Integer money amount to avoid floating point currency issues.
  priceAmount          Int             @map("price_amount")
  /// ISO currency code.
  currency             String          @default("USD") @db.VarChar(3)
  /// Monthly/yearly/custom billing cadence.
  billingInterval      BillingInterval @map("billing_interval")
  /// Max number of active jobs allowed on the plan.
  activeJobsLimit      Int?            @map("active_jobs_limit")
  /// Max number of team members allowed on the plan.
  teamMembersLimit     Int?            @map("team_members_limit")
  /// Max number of contact unlocks per period.
  candidateUnlockLimit Int?            @map("candidate_unlock_limit")
  /// Max number of CV parsing actions per period.
  cvParsingLimit       Int?            @map("cv_parsing_limit")
  /// Non-numeric analytics entitlement descriptor.
  analyticsTier        String?         @map("analytics_tier") @db.VarChar(50)
  /// Whether API access is enabled.
  apiAccess            Boolean         @default(false) @map("api_access")
  /// Support SLA/tier label.
  supportTier          String?         @map("support_tier") @db.VarChar(50)
  /// Row creation timestamp.
  createdAt            DateTime        @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt            DateTime        @updatedAt @map("updated_at")
  /// Subscriptions currently or historically referencing this plan.
  subscriptions        Subscription[]

  @@map("subscription_plans")
}

/// Tenant's actual subscription state.
/// This links a tenant to a plan and keeps Stripe/billing lifecycle data.
model Subscription {
  /// Primary key for the subscription record.
  id                   String             @id @default(uuid()) @db.Uuid
  /// Tenant that owns this subscription.
  tenantId             String             @unique @map("tenant_id") @db.Uuid
  /// Plan currently assigned to the tenant.
  planId               String             @map("plan_id") @db.Uuid
  /// Stripe-side subscription identifier for sync and webhooks.
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  /// Stripe customer identifier.
  stripeCustomerId     String?            @map("stripe_customer_id")
  /// Billing status that gates features and access.
  status               SubscriptionStatus
  /// Billing period start used for usage windows and invoicing.
  currentPeriodStart   DateTime?          @map("current_period_start")
  /// Billing period end used for usage windows and invoicing.
  currentPeriodEnd     DateTime?          @map("current_period_end")
  /// Scheduled cancellation time if applicable.
  cancelAt             DateTime?          @map("cancel_at")
  /// Actual cancellation completion time.
  canceledAt           DateTime?          @map("canceled_at")
  /// Row creation timestamp.
  createdAt            DateTime           @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt            DateTime           @updatedAt @map("updated_at")
  /// Tenant relation.
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Plan relation.
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId, status])
  @@map("subscriptions")
}

/// Usage counter for a specific quota feature and billing period.
/// Keeps plan definition separate from actual consumption.
model QuotaUsage {
  /// Primary key for quota usage row.
  id          String       @id @default(uuid()) @db.Uuid
  /// Tenant consuming the quota.
  tenantId    String       @map("tenant_id") @db.Uuid
  /// Feature being tracked, e.g. active jobs or CV parsing.
  feature     QuotaFeature
  /// Amount consumed in the tracked period.
  used        Int          @default(0)
  /// Effective limit at the time of tracking for easier reads/audits.
  limit       Int?         @map("limit")
  /// Usage window start.
  periodStart DateTime     @map("period_start")
  /// Usage window end.
  periodEnd   DateTime     @map("period_end")
  /// Flexible metadata for debugging or per-action breakdowns.
  metadata    Json?
  /// Row creation timestamp.
  createdAt   DateTime     @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt   DateTime     @updatedAt @map("updated_at")
  /// Tenant relation.
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature, periodStart, periodEnd])
  @@map("quota_usage")
}

/// Record that a recruiter/tenant unlocked a candidate's contact details.
/// Needed for entitlement enforcement, billing, expiry, and audit trails.
model ContactUnlock {
  /// Primary key for the unlock row.
  id                 String           @id @default(uuid()) @db.Uuid
  /// Tenant consuming unlock quota or credits.
  tenantId           String           @map("tenant_id") @db.Uuid
  /// Candidate whose contact details were unlocked.
  candidateProfileId String           @map("candidate_profile_id") @db.Uuid
  /// Specific user who performed the unlock action.
  unlockedById       String           @map("unlocked_by_id") @db.Uuid
  /// Optional expiry if unlock access is time-limited.
  expiresAt          DateTime?        @map("expires_at")
  /// Row creation timestamp.
  createdAt          DateTime         @default(now()) @map("created_at")
  /// Tenant relation.
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Candidate relation.
  candidateProfile   CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  /// Unlocking user relation.
  unlockedBy         User             @relation(fields: [unlockedById], references: [id], onDelete: Cascade)

  @@unique([tenantId, candidateProfileId, unlockedById])
  @@map("contact_unlocks")
}

/// Notification delivery record across email, in-app, and push channels.
/// Gives the platform a unified communication history per user.
model Notification {
  /// Primary key for the notification row.
  id        String              @id @default(uuid()) @db.Uuid
  /// Recipient user.
  userId    String              @map("user_id") @db.Uuid
  /// Business event category.
  type      NotificationType
  /// Delivery channel used for this record.
  channel   NotificationChannel
  /// Short subject/title for lists and emails.
  title     String              @db.VarChar(255)
  /// Main notification body content.
  body      String
  /// Extra structured data such as deep links and entity ids.
  data      Json?
  /// Delivery state for retries and analytics.
  status    NotificationStatus  @default(PENDING)
  /// Read timestamp for in-app notifications.
  readAt    DateTime?           @map("read_at")
  /// Sent timestamp for delivery tracking.
  sentAt    DateTime?           @map("sent_at")
  /// Row creation timestamp.
  createdAt DateTime            @default(now()) @map("created_at")
  /// User relation.
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@map("notifications")
}

/// Per-user delivery preferences for notifications.
/// Keeps preference logic separate from actual notification records.
model NotificationPreference {
  /// Primary key for the preferences row.
  id              String   @id @default(uuid()) @db.Uuid
  /// One preference row per user.
  userId          String   @unique @map("user_id") @db.Uuid
  /// Whether email notifications are globally enabled.
  emailEnabled    Boolean  @default(true) @map("email_enabled")
  /// Whether in-app notifications are globally enabled.
  inAppEnabled    Boolean  @default(true) @map("in_app_enabled")
  /// Whether push notifications are globally enabled.
  pushEnabled     Boolean  @default(false) @map("push_enabled")
  /// Start of do-not-disturb window.
  quietHoursStart String?  @map("quiet_hours_start") @db.VarChar(5)
  /// End of do-not-disturb window.
  quietHoursEnd   String?  @map("quiet_hours_end") @db.VarChar(5)
  /// Fine-grained per-type preferences payload.
  preferences     Json?
  /// Row creation timestamp.
  createdAt       DateTime @default(now()) @map("created_at")
  /// Row update timestamp.
  updatedAt       DateTime @updatedAt @map("updated_at")
  /// User relation.
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

/// External webhook event log, primarily for Stripe-style idempotent processing.
/// This provides replayability, deduplication, and operational visibility.
model WebhookEvent {
  /// Primary key for the webhook log row.
  id            String    @id @default(uuid()) @db.Uuid
  /// Optional tenant affected by the event.
  tenantId      String?   @map("tenant_id") @db.Uuid
  /// Source provider, e.g. stripe.
  provider      String    @db.VarChar(50)
  /// Provider-side event id used for idempotency.
  eventId       String    @unique @map("event_id")
  /// Event type/category from the provider.
  eventType     String    @map("event_type") @db.VarChar(120)
  /// Full payload received from the provider.
  payload       Json
  /// Timestamp when processing completed successfully.
  processedAt   DateTime? @map("processed_at")
  /// Timestamp when processing failed.
  failedAt      DateTime? @map("failed_at")
  /// Human-readable failure reason for debugging/retry workflows.
  failureReason String?   @map("failure_reason")
  /// Row creation timestamp.
  createdAt     DateTime  @default(now()) @map("created_at")
  /// Tenant relation when event scope is tenant-specific.
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([provider, eventType])
  @@map("webhook_events")
}
